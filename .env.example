APP_NAME=esic-service
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=prisma-certification
# Opcional: si las firmas viven en otro bucket. Vacío = usa S3_BUCKET_NAME.
S3_SIGNATURE_BUCKET_NAME=
SIGNATURE_TEMPLATE_PREFIX=firmas_institucionales/westfield
